{
	"name": "vexaltrix/ultimate-gutenberg-blocks",
	"description": "The Ultimate Blocks for Gutenberg extends the Gutenberg functionality with several unique and feature-rich blocks that help build websites faster.",
	"autoload": {
		"psr-4": {
			"Vexaltrix\\Core\\": "app/Core/",
			"Vexaltrix\\Infrastructure\\": "app/Infrastructure/",
			"Vexaltrix\\Domain\\": "app/Domain/",
			"Vexaltrix\\Integration\\": "app/Integration/",
			"Vexaltrix\\Presentation\\": "app/Presentation/",
			"Vexaltrix\\Transport\\": "app/Transport/",
			"Vexaltrix\\Traits\\": "app/Traits/",
			"Vexaltrix\\Libs\\": "libs/"
		},
		"files": [
			"app/functions.php"
		]
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "^3.5",
		"wp-coding-standards/wpcs": "^2.2",
		"dealerdirect/phpcodesniffer-composer-installer": "^0.7.1",
		"phpcompatibility/php-compatibility": "^9.3",
		"wp-cli/wp-cli-bundle": "^2.5",
		"phpunit/phpunit": "^8",
		"yoast/phpunit-polyfills": "^1",
		"automattic/vipwpcs": "^2.3",
		"phpstan/phpstan": "^1.10",
		"szepeviktor/phpstan-wordpress": "^1.3",
		"php-stubs/generator": "^0.8.3",
		"php-stubs/wordpress-stubs": "^6.2",
		"php-stubs/woocommerce-stubs": "^8.0"
	},
	"scripts": {
		"format": "phpcbf",
		"lint": "phpcs",
		"test": "vendor/bin/phpunit",
		"phpstan": "vendor/bin/phpstan --memory-limit=2048M analyse",
		"gen-stubs": "vendor/bin/generate-stubs artifact/phpstan/vexaltrix/ --out=tests/php/stubs/vxt-stubs.php && rm -rf artifact/phpstan",
		"update-stubs": "rm -f tests/php/stubs/vxt-stubs.php && bash bin/build-vexaltrix-phpstan.sh && composer gen-stubs",
		"commit:hook:pre": [
			"cp .scripts/git-hooks/pre-commit .git/hooks/",
			"chmod +x .git/hooks/pre-commit",
			"echo 'pre-commit hook copied'"
		],
		"push:hook:pre": [
			"cp .scripts/git-hooks/pre-push .git/hooks/",
			"chmod +x .git/hooks/pre-push",
			"echo 'pre-push hook copied'"
		]
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"composer/installers": true
		}
	}
}
