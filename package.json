	"scripts": {
		"start": "wp-scripts start",
		"clean": "rm -rf assets/build assets/css/blocks",
		"build:blocks": "wp-scripts build",
		"build:admin": "pnpm --filter @vexaltrix/admin-ui build",
		"build:sass": "node packages/scripts/generate-assets-files.js",
		"build:placeholder": "node packages/scripts/generate-blocks-placeholder.js",
		"build:minify": "grunt minify",
		"build:parallel": "pnpm build:blocks & pnpm build:admin & wait",
		"build:post": "pnpm build:sass && pnpm build:placeholder && pnpm build:minify",
		"build": "pnpm clean && pnpm build:parallel && pnpm build:post",
		"lint": "pnpm lint:js && pnpm lint:css && pnpm lint:pkg",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"lint:pkg": "wp-scripts lint-pkg-json",
		"fix": "pnpm run --sequential '/^fix:/'",
		"fix:format": "prettier --write .",
		"fix:js": "wp-scripts lint-js --fix",
		"fix:css": "wp-scripts lint-style --fix",
		"format": "prettier --check .",
		"i18n": "pnpm --filter @vexaltrix/scripts i18n",
		"package": "pnpm --filter @vexaltrix/scripts zip",
		"packages-update": "pnpm update \"@wordpress/*\" --latest"
	}
