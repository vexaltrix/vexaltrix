# ignore PHPStorm extra directories
.idea/

# Leave node_modules from git
node_modules/

# sass cache
.sass-cache

# map files
*.map

# Skip package file from versoning
*.zip

# ignore PHPCS report files
phpcs-summary.log
phpcs-full.log

# Exclude OS specific files
.DS_Store

# Exclude composer's directories
vendor/
vexaltrix.zip

# Exclude webpack files.
# config/webpack.config.dev.js
# config/webpack.config.prod.js
# .stylelintrc

# Auth
auth.json

# phpunit
.phpunit.result.cache

# nvmrc
.nvmrc

# VScode
.vscode

# Artifact
artifact/

# BSF Analytics audit working files
.analytics-audit/

# Local code intelligence cache
.codegraph/

# Package lock files
*-lock.json
admin-ui/*-lock.json

#pnpm lock files
*-lock.yaml
admin-ui/*-lock.yaml

# Build/Dist directories (which have a corresponding src directory)
# Generated by root webpack (wp-scripts build)
assets/build/
# Generated by admin-ui webpack (pnpm --filter @vexaltrix/admin-ui build)
assets/admin-ui/
# Generated by SASS generator (packages/scripts/generate-assets-files.js)
assets/css/blocks/
lib/**/dist/
lib/one-onboarding/build/

# Generated minified and RTL CSS files (Created by grunt minify / cssmin or webpack)
assets/css/aos.min.css
assets/css/block-positioning.min.css
assets/css/popup-builder-admin.min.css
assets/css/slick.min.css
assets/css/style-blocks-rtl.min.css
# Generated by webpack build (wp-scripts build)
assets/css/style-blocks-rtl.css
assets/css/visibility.min.css

# Generated minified JS files (Created by grunt minify / uglify task)
assets/js/animations.min.js
assets/js/aos.min.js
assets/js/block-positioning.min.js
assets/js/counter.min.js
assets/js/cross-site-cp-helper.min.js
assets/js/faq.min.js
assets/js/forms.min.js
assets/js/image-gallery.min.js
assets/js/inline-notice.min.js
assets/js/login.min.js
assets/js/lottie.min.js
assets/js/modal.min.js
assets/js/popup-builder-admin.min.js
assets/js/post.min.js
assets/js/register.min.js
assets/js/table-of-contents.min.js
assets/js/tabs.min.js
assets/js/testimonial.min.js
assets/js/timeline.min.js
assets/js/uagb-button-child.min.js
assets/js/uagb-countdown.min.js
